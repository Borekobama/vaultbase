{
  "name": "vaultbase",
  "private": true,
  "version": "0.2.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:api": "tsx watch server/index.ts",
    "db:migrate": "tsx server/migrate.ts",
    "db:mirror": "tsx server/mirror-cli.ts",
    "db:mirror:check": "tsx server/mirror-check.ts",
    "backup:project": "tsx server/backup-cli.ts",
    "restore:verify": "tsx server/verify-cli.ts",
    "backup:retention": "tsx server/retention-cli.ts",
    "build": "tsc -b && vite build && tsc -p tsconfig.server.build.json",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@fontsource-variable/geist": "^5.2.9",
    "archiver": "^8.0.0",
    "croner": "^10.0.1",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "express-rate-limit": "^8.1.0",
    "fflate": "^0.8.2",
    "helmet": "^8.1.0",
    "lucide-react": "^0.468.0",
    "pg": "^8.16.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.1",
    "@types/archiver": "^8.0.0",
    "@types/express": "^5.0.3",
    "@types/pg": "^8.15.5",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^6.0.0",
    "axe-core": "^4.11.1",
    "jsdom": "^28.1.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.0",
    "vite": "^8.1.0",
    "vitest": "^4.1.0"
  }
}
