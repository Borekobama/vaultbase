# Copy to /etc/vaultbase/r2.env on the runner. Never commit the real file.
R2_ENDPOINT=https://9b7d41a22815b37d87c6115d3f774afb.r2.cloudflarestorage.com
R2_BUCKET=vaultbase-backup
R2_REGION=auto

# Create a Cloudflare R2 S3 API token scoped to this bucket.
AWS_ACCESS_KEY_ID=replace-with-r2-access-key-id
AWS_SECRET_ACCESS_KEY=replace-with-r2-secret-access-key

# Restic uses the S3-compatible repository URL and an independent encryption password.
RESTIC_REPOSITORY=s3:https://9b7d41a22815b37d87c6115d3f774afb.r2.cloudflarestorage.com/vaultbase-backup
# Set this outside this file if possible:
# RESTIC_PASSWORD_FILE=/etc/vaultbase/restic-password
