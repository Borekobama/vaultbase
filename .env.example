PROJECT=vaultbase
BUILDER=b-vaultbase
VAULTBASE_PORT=12013
NGINX_DOMAIN=vaultbase.example.com
PUBLIC_ORIGIN=https://vaultbase.example.com
POSTGRES_PASSWORD=replace-with-a-long-random-password
VAULTBASE_API_TOKEN=replace-with-at-least-32-random-characters
VAULTBASE_MASTER_KEY=replace-with-64-hex-characters
MIRROR_DATABASE_URL=postgresql://postgres.PROJECT_REF:ENCODED_PASSWORD@REGION.pooler.supabase.com:6543/postgres
TZ=Europe/Zurich

# Cloudflare R2 / Restic. These remain only in the ignored .env; deploy.sh
# materializes root-readable container secret files automatically.
AWS_ACCESS_KEY_ID=replace-with-r2-access-key-id
AWS_SECRET_ACCESS_KEY=replace-with-r2-secret-access-key
AWS_DEFAULT_REGION=auto
RESTIC_REPOSITORY=s3:https://ACCOUNT_ID.r2.cloudflarestorage.com/BUCKET_NAME
# Existing repositories require their original password. Never generate a replacement.
RESTIC_PASSWORD=replace-with-original-restic-password
