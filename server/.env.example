LOCAL_DATABASE_URL=postgresql:///vaultbase
MIRROR_DATABASE_URL=postgresql://postgres.PROJECT_REF:ENCODED_PASSWORD@REGION.pooler.supabase.com:6543/postgres
VAULTBASE_API_TOKEN=replace-with-at-least-32-random-characters
VAULTBASE_MASTER_KEY=replace-with-64-hex-characters
SECRETS_DIRECTORY=/var/lib/vaultbase/secrets
API_PORT=8787
NODE_ENV=production
SERVE_STATIC=true
PUBLIC_ORIGIN=https://vaultbase.example.com
MIRROR_ENABLED=true
MIRROR_SCHEDULE=15 3 * * *
R2_ENV_FILE=/etc/vaultbase/r2.env
RESTIC_PASSWORD_FILE=/etc/vaultbase/restic-password
PG_BIN_DIRECTORY=/usr/lib/postgresql/17/bin
STORAGE_CACHE_DIRECTORY=/var/lib/vaultbase/storage-cache
