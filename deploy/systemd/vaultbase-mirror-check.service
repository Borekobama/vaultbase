[Unit]
Description=Verify Vaultbase metadata mirror
After=vaultbase-mirror.service

[Service]
Type=oneshot
User=vaultbase
Group=vaultbase
WorkingDirectory=/opt/vaultbase
EnvironmentFile=/etc/vaultbase/api.env
ExecStart=/usr/bin/npm run db:mirror:check
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectHome=true
UMask=0077
