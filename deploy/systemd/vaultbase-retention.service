[Unit]
Description=Apply Vaultbase Restic retention and prune unused packs
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
User=vaultbase
Group=vaultbase
WorkingDirectory=/opt/vaultbase
EnvironmentFile=/etc/vaultbase/api.env
ExecStart=/usr/bin/npm run backup:retention -- --prune
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectHome=true
ReadWritePaths=/var/lib/vaultbase /var/cache/vaultbase
UMask=0077
